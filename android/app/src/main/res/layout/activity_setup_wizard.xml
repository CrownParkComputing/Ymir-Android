<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#101418"
    android:padding="24dp"
    tools:context=".SetupWizardActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/setup_title"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/step_welcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_welcome_title"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_welcome_text"
                    android:textColor="#CDD5DF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginBottom="16dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/step_app"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_app_title"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_app_explanation"
                    android:textColor="#CDD5DF"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="20dp" />

                <Button
                    android:id="@+id/select_app_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_select_app"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#3B82F6"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/app_status_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_app_not_selected"
                    android:textColor="#F59E0B"
                    android:textSize="13sp"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/step_bios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_bios_title"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_bios_explanation"
                    android:textColor="#CDD5DF"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="20dp" />

                <Button
                    android:id="@+id/select_bios_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_select_bios"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#22C55E"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/bios_status_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_bios_not_selected"
                    android:textColor="#F59E0B"
                    android:textSize="13sp"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/step_games"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_games_title"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_games_explanation"
                    android:textColor="#CDD5DF"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="20dp" />

                <Button
                    android:id="@+id/select_games_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_select_games"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#A855F7"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/games_status_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_games_not_selected"
                    android:textColor="#F59E0B"
                    android:textSize="13sp"
                    android:gravity="center" />
            </LinearLayout>

        </FrameLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/back_button"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="@string/setup_back"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4B5563"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/next_button"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:text="@string/setup_next"
            android:textColor="#FFFFFF"
            android:backgroundTint="#16A34A"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
