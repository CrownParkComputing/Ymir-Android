sdk.dir=/path/to/Android/Sdk

# Optional local IGDB credentials. CI release builds read these from repository
# secrets instead.
# IGDB_CLIENT_ID=
# IGDB_CLIENT_SECRET=

# Optional local release signing. CI release builds decode the keystore from
# ANDROID_KEYSTORE_BASE64 and provide these values as repository secrets.
# ANDROID_KEYSTORE_PATH=/path/to/upload-key.jks
# ANDROID_KEYSTORE_PASSWORD=
# ANDROID_KEY_ALIAS=
# ANDROID_KEY_PASSWORD=
